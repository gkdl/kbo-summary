{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://104.198.2.246:8080"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://172.30.1.22:8080"
      }
    },
    "preview-emulator": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://104.198.2.246:8080"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://104.198.2.246:8080"
      }
    },
    "store": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://104.198.2.246:8080"
      }
    }
  },
  "submit": {
    "production": {},
    "store": {
      "android": {
        "track": "production",
        "releaseStatus": "draft"
      }
    }
  }
