# ===== Spring =====
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# ===== Oracle Database =====
# docker-compose 가 DB_USERNAME/DB_PASSWORD 를 ORACLE_USER/ORACLE_PASSWORD 로 매핑한다
DB_USERNAME=kbo
DB_PASSWORD=changeme

# 직접 application-*.yml 이 참조하는 변수 (compose 외부에서 실행 시)
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=XEPDB1
ORACLE_USER=${DB_USERNAME}
ORACLE_PASSWORD=${DB_PASSWORD}

# ===== Google Gemini =====
# https://aistudio.google.com/apikey 에서 무료 발급 (신용카드 불필요).
# 비어 있으면 경기 요약은 fallback 문구로 대체된다. gemini-2.0-flash 무료 한도: 일일 1,500회.
GEMINI_API_KEY=

# ===== KBO 크롤러 =====
KBO_CRAWLER_BASE_URL=https://www.koreabaseball.com

# ===== Mobile (Expo) =====
# 빌드 시 클라이언트에 노출되므로 시크릿 값은 넣지 말 것
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
