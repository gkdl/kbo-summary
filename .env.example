# ===== Spring =====
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# ===== Oracle Database (Autonomous DB / wallet 사용) =====
#
# JDBC URL 의 _tp / _high / _medium / _low 는 tnsnames.ora 의 service alias 이고
# wallet 안 cwallet.sso 가 mTLS 인증, sqlnet.ora 가 wallet 위치를 가리킨다.
#
# 로컬:
#   TNS_ADMIN=C:\oracle\Wallet_p0mpe7dp2i5vywqf  (wallet 폴더 경로)
#   DB_PASSWORD=실제비밀번호
#
# Railway (Dockerfile 진입점이 자동 디코딩):
#   scripts\encode-wallet.ps1 -WalletPath C:\oracle\Wallet_xxx 실행
#   → scripts\.wallet.b64.txt 생성
#   → Railway Variables 에 WALLET_B64 = (그 파일 내용) 등록
#   → DB_PASSWORD 도 Railway Variables 에 별도 등록
DB_URL=jdbc:oracle:thin:@p0mpe7dp2i5vywqf_tp
DB_USERNAME=SCRIPT
DB_PASSWORD=
# Railway 전용 — 로컬에선 비워둠 (대신 TNS_ADMIN 사용)
WALLET_B64=

# ===== Google Gemini =====
# https://aistudio.google.com/apikey 에서 무료 발급 (신용카드 불필요).
# 비어 있으면 경기 요약은 fallback 문구로 대체된다. gemini-2.0-flash 무료 한도: 일일 1,500회.
GEMINI_API_KEY=

# ===== KBO 크롤러 =====
KBO_CRAWLER_BASE_URL=https://www.koreabaseball.com

# ===== Mobile (Expo) =====
# 빌드 시 클라이언트에 노출되므로 시크릿 값은 넣지 말 것
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
